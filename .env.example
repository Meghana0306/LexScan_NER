# LexScan - copy to .env and adjust (optional variables for production layers)
# Existing app: ai_helper.py already reads GROQ_API_KEY from .env

# --- API keys (existing + future) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- App server (defaults match app.py) ---
APP_HOST=127.0.0.1
APP_PORT=7860

# --- Model paths (defaults: ./models/<domain>_best_model) ---
# MODELS_DIR=
# MODEL_PATH_GENERAL=
# MODEL_PATH_MEDICAL=
# MODEL_PATH_LEGAL=

# --- Optional data stores ---
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0

# --- Phase 1 foundation feature flags (all default: off / safe) ---
ENABLE_LOGGING=false
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
ENABLE_LOG_SHIPPING=false
LOG_WEBHOOK_URL=

ENABLE_CACHING=false
CACHE_TTL_NER_SECONDS=3600
CACHE_TTL_LANG_SECONDS=86400
CACHE_TTL_DOMAIN_SECONDS=86400

ENABLE_METRICS=false
ENABLE_VALIDATION=false
ENABLE_REQUEST_LOGGING=false
ENABLE_PREPROCESSING=false
ENABLE_MODEL_CACHE=false
ENABLE_CALIBRATION=false
ENABLE_MODEL_TRACKER=false
ENABLE_ACTIVE_LEARNING=false
ENABLE_ADVANCED_VIZ=false
ENABLE_API_KEY_AUTH=false
ENABLE_RATE_LIMIT=false
ENABLE_BACKGROUND_JOBS=false
ENABLE_FEEDBACK_DB=false

# --- Phase 2: monitoring ---
# ENABLE_METRICS=true
# ENABLE_REQUEST_LOGGING=true
# ENABLE_PERFORMANCE_MONITOR=true
# PERF_SLOW_REQUEST_SECONDS=120
# PERF_MIN_MEAN_CONFIDENCE=0.15

# --- Phase 3: data quality & preprocessing ---
# ENABLE_DATA_QUALITY=true
# ENABLE_PREPROCESSING=true

# --- Phase 4: model improvements ---
# ENABLE_MODEL_CACHE=true
# MODEL_CACHE_TTL_SECONDS=3600
# ENABLE_CALIBRATION=true
# CALIBRATION_STORE_PATH=data/calibration.json
# ENABLE_MODEL_TRACKER=true
# MODEL_TRACKER_DIR=logs/model_tracker
# MODEL_TRACKER_ALERT_THRESHOLD=0.70
# ENABLE_ACTIVE_LEARNING=true
# ACTIVE_LEARNING_DIR=logs/active_learning
# ENABLE_API_KEY_AUTH=true
# API_KEYS=replace-with-real-key
# AUTH_EXEMPT_PATHS=/,/static,/api/languages
# ENABLE_RATE_LIMIT=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=120
# RATE_LIMIT_BURST=30
# ENABLE_BACKGROUND_JOBS=true
# BACKGROUND_JOB_TTL_SECONDS=3600
# BACKGROUND_JOB_MAX_WORKERS=2
# ENABLE_FEEDBACK_DB=true
# FEEDBACK_DB_PATH=data/feedback.sqlite3
# WORKSPACE_STORE_PATH=data/workspace.sqlite3

# --- Validation limits (used when validators run explicitly) ---
MAX_DOCUMENT_CHARS=2000000
MAX_UPLOAD_BYTES=52428800
